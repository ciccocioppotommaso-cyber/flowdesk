generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String            @id @default(cuid())
  clerkId            String            @unique
  name               String?
  email              String?
  niche              String?
  objectives         String?
  plan               String            @default("trial")
  verticale          String            @default("food") // "food" | "care"
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  nomeLocale         String?
  indirizzo          String?
  telefono           String?
  sitoWeb            String?
  descrizioneBot     String?
  maxCoperti         Int?
  publicId           String?           @unique
  orariApertura      String?
  serviziOfferti     String?
  regolePrenotazione String?
  menuOfferta        String?
  pagamenti          String?
  infoPratiche       String?
  faq                String?
  appuntamenti       Appuntamento[]
  contents           Content[]
  conversazioni      Conversazione[]
  dipendenti         Dipendente[]
  leads              Lead[]
  requisitiTurni     RequisitiTurni[]
  listaAttesa        ListaAttesa[]
  preventivi         Preventivo[]
  slotDisponibili    SlotDisponibile[]
  tavoli             Tavolo[]
  sale               Sala[]
  gruppiTavoli       GruppoTavoli[]
  turni              Turno[]
  menuCategorie      MenuCategoria[]
  menuPiatti         MenuPiatto[]
  ordini             Ordine[]
  // Personalizzazione pagina ordine
  menuLogoUrl        String?
  menuColoreP        String?           @default("#4f46e5")
  menuColoreS        String?           @default("#ffffff")
  turniServizio      String?           // JSON: [{id, nome, oraInizio, oraFine}]
  fabbisognoStaff   String?           // JSON: [{giorno: 0-6, ruolo: string, persone: number, oraInizio: string, oraFine: string}]
  mapElementi        String?           // JSON: [{id, tipo, label, x, y, w, h, colore}]
  blockAsporto       Boolean           @default(false)
  blockDelivery      Boolean           @default(false)
  // Flowest Care
  pazienti           Paziente[]
  sedute             Seduta[]
  documentiPazienti  DocumentoPaziente[]
  tipiSeduta         TipoSeduta[]
  disponibilitaOverride DisponibilitaOverride[]
}

model MenuCategoria {
  id        String       @id @default(cuid())
  userId    String
  nome      String
  ordine    Int          @default(0)
  tipo      String       @default("locale") // "locale" | "asporto"
  createdAt DateTime     @default(now())
  user      User         @relation(fields: [userId], references: [id])
  piatti    MenuPiatto[]
}

model MenuPiatto {
  id          String        @id @default(cuid())
  userId      String
  categoriaId String
  nome        String
  descrizione String?
  prezzo      Float
  immagineUrl String?
  disponibile Boolean       @default(true)
  ordine      Int           @default(0)
  createdAt   DateTime      @default(now())
  user        User          @relation(fields: [userId], references: [id])
  categoria   MenuCategoria @relation(fields: [categoriaId], references: [id])
  righeOrdine RigaOrdine[]
}

model Ordine {
  id          String        @id @default(cuid())
  userId      String
  tavolo      String
  tavoloId    String?
  gruppoId    String?
  tipo        String        @default("tavolo") // "tavolo" | "asporto" | "delivery"
  clienteInfo String?       // JSON: {nome, email, telefono, indirizzo, data, ora}
  status      String        @default("nuovo")
  totale      Float
  coperti     Int?
  note        String?
  createdAt   DateTime      @default(now())
  closedAt    DateTime?
  user        User          @relation(fields: [userId], references: [id])
  tavoloRel   Tavolo?       @relation(fields: [tavoloId], references: [id])
  gruppoRel   GruppoTavoli? @relation(fields: [gruppoId], references: [id])
  righe       RigaOrdine[]
}

model RigaOrdine {
  id       String     @id @default(cuid())
  ordineId String
  piattoId String
  nome     String
  prezzo   Float
  quantita Int
  note     String?
  ordine   Ordine     @relation(fields: [ordineId], references: [id])
  piatto   MenuPiatto @relation(fields: [piattoId], references: [id])
}

model Lead {
  id         String   @id @default(cuid())
  userId     String
  name       String
  email      String?
  phone      String?
  status     String   @default("nuovo")
  notes      String?
  cancellato Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id])
}

model Content {
  id           String    @id @default(cuid())
  userId       String
  originalText String
  channel      String
  result       String?
  scheduledAt  DateTime?
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id])
}

model Appuntamento {
  id           String   @id @default(cuid())
  userId       String
  clienteNome  String?
  clienteEmail String?
  servizio     String?
  data         DateTime
  durata       Int      @default(60)
  status       String   @default("confermato")
  note         String?
  coperti      Int      @default(1)
  allergie     String?
  occasione    String?
  tavoloId     String?
  tavoliIds    String?
  pazienteId   String?      // Flowest Care: collega l'appuntamento a un paziente
  tipoSedutaId String?      // Flowest Care: collega l'appuntamento a un tipo di seduta
  createdAt    DateTime     @default(now())
  tavolo       Tavolo?      @relation(fields: [tavoloId], references: [id])
  user         User         @relation(fields: [userId], references: [id])
  paziente     Paziente?    @relation(fields: [pazienteId], references: [id])
  tipoSeduta   TipoSeduta?  @relation(fields: [tipoSedutaId], references: [id])
}

// ── Flowest Care ──────────────────────────────────────────────────────────
model Paziente {
  id           String              @id @default(cuid())
  userId       String
  nome         String
  email        String?
  telefono     String?
  dataNascita  DateTime?
  note         String?             // anamnesi / note generali
  cancellato   Boolean             @default(false)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  user         User                @relation(fields: [userId], references: [id])
  sedute       Seduta[]
  documenti    DocumentoPaziente[]
  appuntamenti Appuntamento[]
}

model TipoSeduta {
  id           String         @id @default(cuid())
  userId       String
  nome         String
  descrizione  String?
  prezzo       Float          @default(0)
  durata       Int            @default(45) // minuti
  attivo       Boolean        @default(true)
  ordine       Int            @default(0)
  createdAt    DateTime       @default(now())
  user         User           @relation(fields: [userId], references: [id])
  appuntamenti Appuntamento[]
}

model DisponibilitaOverride {
  id        String   @id @default(cuid())
  userId    String
  data      DateTime // giorno specifico (solo la data conta)
  slots     String   // JSON: ["08:00-14:00","16:00-18:00"] — [] = chiuso quel giorno
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, data])
}

model Seduta {
  id         String   @id @default(cuid())
  userId     String
  pazienteId String
  data       DateTime @default(now())
  tipo       String?  // es. Valutazione, Terapia manuale, Rieducazione posturale
  note       String?  // cosa è stato fatto, dolore percepito, esercizi assegnati
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
  paziente   Paziente @relation(fields: [pazienteId], references: [id])
}

model DocumentoPaziente {
  id         String   @id @default(cuid())
  userId     String
  pazienteId String
  nome       String
  url        String
  tipo       String?  // referto | prescrizione | radiografia | altro
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
  paziente   Paziente @relation(fields: [pazienteId], references: [id])
}

model GruppoTavoli {
  id        String   @id @default(cuid())
  userId    String
  label     String
  data      String?
  turnoId   String?
  oraFine   String?
  auto      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  tavoli    Tavolo[]
  ordini    Ordine[]
}

model Sala {
  id          String   @id @default(cuid())
  userId      String
  nome        String
  ordine      Int      @default(0)
  mapElementi String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  tavoli      Tavolo[]
}

model Tavolo {
  id           String         @id @default(cuid())
  userId       String
  numero       Int
  etichetta    String?
  posti        Int            @default(4)
  note         String?
  gruppoId     String?
  salaId       String?
  mapX         Float?
  mapY         Float?
  mapW         Float?
  mapH         Float?
  mapForma     String?
  mapColore    String?
  createdAt    DateTime       @default(now())
  appuntamenti Appuntamento[]
  ordini       Ordine[]
  user         User           @relation(fields: [userId], references: [id])
  gruppo       GruppoTavoli?  @relation(fields: [gruppoId], references: [id])
  sala         Sala?          @relation(fields: [salaId], references: [id])
}

model ListaAttesa {
  id           String   @id @default(cuid())
  userId       String
  clienteNome  String
  clienteEmail String?
  clienteTel   String?
  data         DateTime
  ora          String
  coperti      Int      @default(1)
  note         String?
  status       String   @default("in_attesa")
  preventivoId String?
  leadId       String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
}

model Dipendente {
  id          String                @id @default(cuid())
  userId      String
  nome        String
  email       String
  ruolo       String?
  fotoUrl     String?
  username    String?
  passwordHash String?
  mustChangePassword Boolean       @default(true)
  token       String?               @unique
  tokenExpiry DateTime?
  createdAt   DateTime              @default(now())
  user        User                  @relation(fields: [userId], references: [id])
  richieste        RichiestaDipendente[]
  turni            Turno[]
  disponibilita    DisponibilitaDipendente[]
  timbrature       Timbratura[]

  @@unique([userId, username])
}

model Timbratura {
  id           String     @id @default(cuid())
  dipendenteId String
  dipendente   Dipendente @relation(fields: [dipendenteId], references: [id], onDelete: Cascade)
  userId       String
  tipo         String     // "entrata" | "uscita"
  timestamp    DateTime   @default(now())
}

model Turno {
  id           String     @id @default(cuid())
  userId       String
  dipendenteId String
  data         DateTime
  oraInizio    String
  oraFine      String
  ruolo        String?
  note         String?
  createdAt    DateTime   @default(now())
  dipendente   Dipendente @relation(fields: [dipendenteId], references: [id])
  user         User       @relation(fields: [userId], references: [id])
}

model RichiestaDipendente {
  id           String     @id @default(cuid())
  dipendenteId String
  tipo         String
  data         DateTime?
  dataFine     DateTime?
  note         String?
  oraInizio    String?
  oraFine      String?
  status       String     @default("in_attesa")
  createdAt    DateTime   @default(now())
  dipendente   Dipendente @relation(fields: [dipendenteId], references: [id])
}

model DisponibilitaDipendente {
  id           String     @id @default(cuid())
  dipendenteId String
  mese         DateTime   // primo giorno del mese
  giorni       String     // JSON: [{data: "2026-07-07", oraInizio: "09:00", oraFine: "17:00", note: ""}]
  createdAt    DateTime   @default(now())
  dipendente   Dipendente @relation(fields: [dipendenteId], references: [id])

  @@unique([dipendenteId, mese])
}

model RequisitiTurni {
  id        String   @id @default(cuid())
  userId    String
  settimana DateTime
  requisiti String   // JSON: [{giorno: 0-6, fascia: "pranzo"|"cena"|"mattina", persone: 2, ruolo: "cameriere"}]
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, settimana])
}

model SlotDisponibile {
  id        String   @id @default(cuid())
  userId    String
  data      DateTime
  oraInizio String
  oraFine   String
  durata    Int      @default(60)
  user      User     @relation(fields: [userId], references: [id])
}

model Conversazione {
  id           String   @id @default(cuid())
  userId       String
  clienteNome  String?
  clienteEmail String?
  canale       String   @default("chat")
  messaggi     String
  letta        Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id])
}

model Preventivo {
  id                String   @id @default(cuid())
  userId            String
  leadId            String?
  numero            Int
  tipo              String   @default("preventivo")
  clienteName       String
  clienteEmail      String?
  items             String
  totale            Float
  status            String   @default("bozza")
  note              String?
  tavoliIds         String?
  tokenRisposta     String?  @unique
  messaggioProposta String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id])
}
