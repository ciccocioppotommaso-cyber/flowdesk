generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String            @id @default(cuid())
  clerkId            String            @unique
  name               String?
  email              String?
  niche              String?
  objectives         String?
  plan               String            @default("trial")
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  nomeLocale         String?
  indirizzo          String?
  telefono           String?
  sitoWeb            String?
  descrizioneBot     String?
  maxCoperti         Int?
  publicId           String?           @unique
  orariApertura      String?
  serviziOfferti     String?
  regolePrenotazione String?
  menuOfferta        String?
  pagamenti          String?
  infoPratiche       String?
  faq                String?
  appuntamenti       Appuntamento[]
  contents           Content[]
  conversazioni      Conversazione[]
  dipendenti         Dipendente[]
  leads              Lead[]
  requisitiTurni     RequisitiTurni[]
  listaAttesa        ListaAttesa[]
  preventivi         Preventivo[]
  slotDisponibili    SlotDisponibile[]
  tavoli             Tavolo[]
  turni              Turno[]
}

model Lead {
  id         String   @id @default(cuid())
  userId     String
  name       String
  email      String?
  phone      String?
  status     String   @default("nuovo")
  notes      String?
  cancellato Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id])
}

model Content {
  id           String    @id @default(cuid())
  userId       String
  originalText String
  channel      String
  result       String?
  scheduledAt  DateTime?
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id])
}

model Appuntamento {
  id           String   @id @default(cuid())
  userId       String
  clienteNome  String?
  clienteEmail String?
  servizio     String?
  data         DateTime
  durata       Int      @default(60)
  status       String   @default("confermato")
  note         String?
  coperti      Int      @default(1)
  allergie     String?
  occasione    String?
  tavoloId     String?
  createdAt    DateTime @default(now())
  tavolo       Tavolo?  @relation(fields: [tavoloId], references: [id])
  user         User     @relation(fields: [userId], references: [id])
}

model Tavolo {
  id           String         @id @default(cuid())
  userId       String
  numero       Int
  posti        Int
  note         String?
  createdAt    DateTime       @default(now())
  appuntamenti Appuntamento[]
  user         User           @relation(fields: [userId], references: [id])
}

model ListaAttesa {
  id           String   @id @default(cuid())
  userId       String
  clienteNome  String
  clienteEmail String?
  clienteTel   String?
  data         DateTime
  ora          String
  coperti      Int      @default(1)
  note         String?
  status       String   @default("in_attesa")
  preventivoId String?
  leadId       String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id])
}

model Dipendente {
  id          String                @id @default(cuid())
  userId      String
  nome        String
  email       String
  ruolo       String?
  token       String?               @unique
  tokenExpiry DateTime?
  createdAt   DateTime              @default(now())
  user        User                  @relation(fields: [userId], references: [id])
  richieste        RichiestaDipendente[]
  turni            Turno[]
  disponibilita    DisponibilitaDipendente[]
}

model Turno {
  id           String     @id @default(cuid())
  userId       String
  dipendenteId String
  data         DateTime
  oraInizio    String
  oraFine      String
  ruolo        String?
  note         String?
  createdAt    DateTime   @default(now())
  dipendente   Dipendente @relation(fields: [dipendenteId], references: [id])
  user         User       @relation(fields: [userId], references: [id])
}

model RichiestaDipendente {
  id           String     @id @default(cuid())
  dipendenteId String
  tipo         String
  data         DateTime?
  dataFine     DateTime?
  note         String?
  status       String     @default("in_attesa")
  createdAt    DateTime   @default(now())
  dipendente   Dipendente @relation(fields: [dipendenteId], references: [id])
}

model DisponibilitaDipendente {
  id           String     @id @default(cuid())
  dipendenteId String
  mese         DateTime   // primo giorno del mese
  giorni       String     // JSON: [{data: "2026-07-07", oraInizio: "09:00", oraFine: "17:00", note: ""}]
  createdAt    DateTime   @default(now())
  dipendente   Dipendente @relation(fields: [dipendenteId], references: [id])

  @@unique([dipendenteId, mese])
}

model RequisitiTurni {
  id        String   @id @default(cuid())
  userId    String
  settimana DateTime
  requisiti String   // JSON: [{giorno: 0-6, fascia: "pranzo"|"cena"|"mattina", persone: 2, ruolo: "cameriere"}]
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, settimana])
}

model SlotDisponibile {
  id        String   @id @default(cuid())
  userId    String
  data      DateTime
  oraInizio String
  oraFine   String
  durata    Int      @default(60)
  user      User     @relation(fields: [userId], references: [id])
}

model Conversazione {
  id           String   @id @default(cuid())
  userId       String
  clienteNome  String?
  clienteEmail String?
  canale       String   @default("chat")
  messaggi     String
  letta        Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id])
}

model Preventivo {
  id                String   @id @default(cuid())
  userId            String
  leadId            String?
  numero            Int
  tipo              String   @default("preventivo")
  clienteName       String
  clienteEmail      String?
  items             String
  totale            Float
  status            String   @default("bozza")
  note              String?
  tokenRisposta     String?  @unique
  messaggioProposta String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id])
}
